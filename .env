############################################
# GENERAL APPLICATION SETTINGS
############################################

FLASK_ENV=production
FLASK_DEBUG=0
APP_NAME=ExamApp
APP_URL=http://localhost:8000

SECRET_KEY=change-this-to-a-super-long-random-string
SECURITY_PASSWORD_SALT=change-this-too


############################################
# DATABASE (PostgreSQL)
############################################

DB_ENGINE=postgresql
DB_HOST=db
DB_PORT=5432
DB_NAME=examdb
DB_USERNAME=examuser
DB_PASSWORD=strongpassword

DATABASE_URL=postgresql://examuser:strongpassword@db:5432/examdb


############################################
# JWT CONFIGURATION
############################################

JWT_SECRET_KEY=replace-with-another-long-random-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30


############################################
# GOOGLE OAUTH (Login with Google)
############################################

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback


############################################
# ADMIN USER (AUTO CREATE ON FIRST RUN)
############################################

ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@examapp.com
ADMIN_PASSWORD=Admin@12345
ADMIN_ROLE=ADMIN


############################################
# MAIL SERVER (optional)
############################################

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=Exam App <your_email@gmail.com>


############################################
# REDIS (Optional – for caching / sessions later)
############################################

REDIS_URL=redis://redis:6379/0


############################################
# LOGGING
############################################

LOG_LEVEL=INFO
SENTRY_DSN=


############################################
# CORS / SECURITY
############################################

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SESSION_COOKIE_SECURE=True
REMEMBER_COOKIE_SECURE=True
